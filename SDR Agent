      const p = parseJ(texts);
      if (p?.emails?.length) {
        const map = {};
        p.emails.forEach(e => { if (e.email) map[e.email] = e; });
        valid.forEach(c => { if (!map[c.email]) { const m = p.emails.find(e => e.name === c.name); if (m) map[c.email] = { ...m, email: c.email }; } });
        setEmailCache(prev => {
          const merged = { ...prev, [acct.n]: { ...(prev[acct.n] || {}), ...map } };
          try { window.storage.set("mc_emails_v1", JSON.stringify(merged)); } catch {}
          return merged;
        });
        return map;
      }
    } catch (e) { log(`✗ ${acct.n}: ${e.message?.slice(0,30)}`); }
    return {};
  }, [companyPriorities, log]);

  // ─── AGENT: Auto-run on mount — priorities then emails for T1 ───
  const agentRunRef = useRef(false);
  useEffect(() => {
    if (agentRunRef.current) return;
    agentRunRef.current = true;
    const run = async () => {
      // Wait for priorities to load (at least 50%)
      setAgentPhase("priorities");
      setAgentProgress("Loading company priorities...");
      const waitPri = () => new Promise(res => {
        const check = () => { if (Object.keys(companyPriorities).length >= Math.min(ACCTS.length, 20) || prioritiesLoaded) res(); else setTimeout(check, 3000); };
        setTimeout(check, 5000); // give priorities a head start
      });
      await waitPri();

      // Generate emails for all Tier 1 accounts with contacts
      setAgentPhase("emails");
      const tier1 = ACCTS.filter(a => a.t === 1 && FC[a.n]?.length > 0);
      for (let i = 0; i < tier1.length; i++) {
        const a = tier1[i];
        if (emailCache[a.n] && Object.keys(emailCache[a.n]).length > 0) continue; // already cached
        setAgentProgress(`Emails: ${a.n} (${i+1}/${tier1.length})`);
        const list = FC[a.n].map(c => ({ ...c, source: "Plan", phone: "", linkedin: "", prior: "None" }));
        await genAndCache(a, list);
        await new Promise(r => setTimeout(r, 300));
      }
      setAgentPhase("done");
      setAgentProgress(`Ready — ${tier1.length} accounts, all emails generated`);
      log("Agent complete — Tier 1 accounts ready with contacts and emails");
    };
    setTimeout(run, 2000);
  }, [companyPriorities, prioritiesLoaded, emailCache, genAndCache, log]);

  // Open contacts panel — use cached data instantly
  const openContacts = (acct) => {
    genRef.current = acct.n;
    setContactsAcct(acct);
    setDraftStatus({});

    // Load contacts
    const list = FC[acct.n]?.map(c => ({ ...c, source: "Plan", phone: "", linkedin: "", prior: "None" })) || [];
    setContacts(list);

    // Load cached emails or generate
    const cached = emailCache[acct.n];
    if (cached && Object.keys(cached).length > 0) {
      setEmailMap(cached);
      setLoadingEmails({});
    } else {
      setEmailMap({});
      setLoadingEmails({});
      if (list.length) genAndCache(acct, list).then(map => { if (genRef.current === acct.n) setEmailMap(map); });
    }
  };

  const filtered = accounts.filter(a => {
    if (filter && a.t !== filter) return false;
    if (search) { const s = search.toLowerCase(); return a.n.toLowerCase().includes(s) || a.ind?.toLowerCase().includes(s) || a.ci?.toLowerCase().includes(s); }
    return true;
  });
  const isActive = loading || Object.values(loadingEmails).some(Boolean) || Object.values(loadingPriorities).some(Boolean) || agentPhase === "emails";
  const priCount = Object.keys(companyPriorities).length;
  const emailCacheCount = Object.values(emailCache).reduce((sum, m) => sum + Object.keys(m).length, 0);
  const ec = Object.keys(emailMap).length;

  return (
    <div style={{ fontFamily: "'DM Sans', -apple-system, sans-serif", background: MC.bg, color: MC.text, minHeight: "100vh", padding: "20px 24px" }}>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

      {/* Header */}
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 20 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <div style={{ width: 32, height: 32, borderRadius: 8, background: `linear-gradient(135deg, ${MC.green}, ${MC.purple})`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 13, fontWeight: 700, color: MC.bg }}>MC</div>
          <div>
            <h1 style={{ fontSize: 18, fontWeight: 700, margin: 0 }}>Territory Agent</h1>
            <div style={{ fontSize: 11, color: MC.textMuted }}>Connor Miller · Pacific Northwest</div>
          </div>
        </div>
        <div style={{ display: "flex", gap: 14, alignItems: "center", fontSize: 11, fontFamily: "'DM Mono', monospace" }}>
          <div style={{ display: "flex", alignItems: "center", gap: 5 }}><div style={{ width: 6, height: 6, borderRadius: "50%", background: isActive ? MC.green : MC.textFaint, boxShadow: isActive ? `0 0 8px ${MC.green}` : "none", transition: "all .3s" }} /><span style={{ color: MC.textMuted }}>{accounts.length} accounts</span></div>
          <span style={{ color: TC[1] }}>{accounts.filter(a=>a.t===1).length} strategic</span>
          <span style={{ color: TC[2] }}>{accounts.filter(a=>a.t===2).length} growth</span>
          {ec > 0 && <span style={{ color: MC.green }}>{ec} emails</span>}
          <span style={{ color: priCount >= accounts.length ? MC.green : MC.purple }}>{priCount}/{accounts.length} priorities</span>
          {emailCacheCount > 0 && <span style={{ color: MC.green }}>{emailCacheCount} emails cached</span>}
          {agentPhase !== "done" && <span style={{ color: MC.amber }}>{agentProgress || agentPhase}</span>}
        </div>
      </div>

      {/* Filters */}
      <div style={{ display: "flex", gap: 6, marginBottom: 14 }}>
        <input value={search} onChange={e => setSearch(e.target.value)} placeholder="Search accounts..." style={{ flex: 1, maxWidth: 300, padding: "8px 14px", background: MC.bgInput, border: `1px solid ${MC.border}`, borderRadius: 8, color: MC.text, fontSize: 13, outline: "none" }} />
        {[null,1,2,3].map(t => <button key={t??"a"} onClick={() => setFilter(t)} style={{ padding: "6px 14px", borderRadius: 20, border: `1px solid ${filter===t ? (t?TC[t]:MC.green)+"44" : MC.border}`, background: filter===t ? (t?TC[t]:MC.green)+"12" : "transparent", color: filter===t ? (t?TC[t]:MC.green) : MC.textMuted, fontSize: 11, fontWeight: 500, cursor: "pointer" }}>{t ? TL[t] : "All"}</button>)}
      </div>

      {/* Layout: accounts list + optional contacts panel */}
      <div style={{ display: "grid", gridTemplateColumns: contactsAcct ? "1fr 1fr" : "1fr", gap: 16 }}>

        {/* LEFT: Account list with expandable tiles */}
        <div style={{ maxHeight: "76vh", overflowY: "auto" }}>
          {filtered.map(a => {
            const isExpanded = expandedAcct === a.id;
            const ct = FC[a.n]?.length || 0;
            const cachedCount = emailCache[a.n] ? Object.keys(emailCache[a.n]).length : 0;
            return (
              <div key={a.id} style={{ background: MC.bgCard, border: `1px solid ${isExpanded ? TC[a.t]+"44" : MC.border}`, borderLeft: `3px solid ${TC[a.t]}`, borderRadius: 10, marginBottom: 6, overflow: "hidden", transition: "all .15s" }}>
                {/* Account header row */}
                <div onClick={() => { const next = isExpanded ? null : a.id; setExpandedAcct(next); if (next && !companyPriorities[a.n] && !loadingPriorities[a.n]) fetchPriorities(a); }} style={{ padding: "12px 16px", cursor: "pointer", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                      <span style={{ fontWeight: 600, fontSize: 14, color: MC.text }}>{a.n}</span>
                      <span style={{ fontSize: 10, fontWeight: 600, color: TC[a.t], background: TC[a.t]+"15", padding: "2px 8px", borderRadius: 10 }}>{TL[a.t]}</span>
                      {a.oo > 0 && <span style={{ fontSize: 10, color: MC.green }}>● Deal</span>}
                    </div>
                    <div style={{ fontSize: 11, color: MC.textMuted, marginTop: 2 }}>{a.ind} · {fmt(a.emp)} emp · {a.ci}{a.st ? `, ${a.st}` : ""}</div>
                  </div>
                  <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
                    {a.is > 0 && <div style={{ fontSize: 10, fontWeight: 600, color: a.is >= 80 ? MC.green : a.is >= 50 ? MC.amber : MC.textFaint, background: a.is >= 80 ? MC.greenBg : a.is >= 50 ? MC.amberBg : "transparent", padding: "2px 6px", borderRadius: 4 }}>{Math.round(a.is)}</div>}
                    <svg width="16" height="16" viewBox="0 0 16 16" style={{ transform: isExpanded ? "rotate(180deg)" : "rotate(0)", transition: "transform .2s", color: MC.textFaint }}><path d="M4 6l4 4 4-4" stroke="currentColor" strokeWidth="1.5" fill="none"/></svg>
                  </div>
                </div>

                {/* Expanded detail */}
                {isExpanded && (
                  <div style={{ padding: "0 16px 14px", borderTop: `1px solid ${MC.border}` }}>
                    
                    {/* Company Priorities — from web research */}
                    <div style={{ marginTop: 10, marginBottom: 10, padding: "10px 14px", background: `linear-gradient(135deg, ${MC.amber}06, ${MC.amber}03)`, borderRadius: 8, border: `1px solid ${MC.amber}22` }}>
                      <div style={{ fontSize: 10, fontWeight: 600, color: MC.amber, letterSpacing: ".04em", marginBottom: 6 }}>COMPANY PRIORITIES</div>
                      {loadingPriorities[a.n] && !companyPriorities[a.n] && (
                        <div style={{ fontSize: 11, color: MC.textFaint, fontStyle: "italic" }}>Researching earnings reports, press releases, and public filings...</div>
                      )}
                      {companyPriorities[a.n]?.map((pr, pi) => (
                        <div key={pi} style={{ fontSize: 12, color: MC.text, lineHeight: 1.5, marginTop: pi > 0 ? 5 : 0, display: "flex", gap: 8, alignItems: "flex-start" }}>
                          <span style={{ color: MC.amber, flexShrink: 0, fontSize: 14, lineHeight: 1.2 }}>{pi + 1}.</span>
                          <span>{pr}</span>
                        </div>
                      ))}
                      {!loadingPriorities[a.n] && !companyPriorities[a.n] && (
                        <button onClick={(e) => { e.stopPropagation(); fetchPriorities(a); }} style={{ fontSize: 11, color: MC.amber, background: "transparent", border: `1px solid ${MC.amberDim}`, borderRadius: 6, padding: "4px 12px", cursor: "pointer" }}>Research Priorities</button>
                      )}
                    </div>

                    {/* Data & AI Priorities — from CRM signals */}
                    {(() => {
                      const priorities = getPriorities(a);
                      return priorities.length > 0 ? (
                        <div style={{ marginBottom: 10, padding: "10px 14px", background: `linear-gradient(135deg, ${MC.purple}08, ${MC.green}08)`, borderRadius: 8, border: `1px solid ${MC.purple}22` }}>
                          <div style={{ fontSize: 10, fontWeight: 600, color: MC.purple, letterSpacing: ".04em", marginBottom: 6 }}>DATA & AI PRIORITIES</div>
                          {priorities.map((pr, pi) => (
                            <div key={pi} style={{ fontSize: 12, color: MC.text, lineHeight: 1.5, marginTop: pi > 0 ? 4 : 0, display: "flex", gap: 8, alignItems: "flex-start" }}>
                              <span style={{ color: MC.green, flexShrink: 0, marginTop: 1 }}>→</span>
                              <span>{pr}</span>
                            </div>
                          ))}
                        </div>
                      ) : null;
                    })()}

                    {/* Company details */}
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "4px 24px" }}>
                      <Detail label="Employees" val={a.emp ? fmt(a.emp) : null} />
                      <Detail label="Lifecycle" val={a.lc || null} />
                      <Detail label="Data Team" val={a.dt ? `${Math.round(a.dt)} people` : null} />
                      <Detail label="6sense" val={a.is ? `${Math.round(a.is)} — ${a.bs}` : null} />
                      <Detail label="Snowflake" val={a.ss || null} />
                      <Detail label="Databricks" val={a.ds || null} />
                    </div>
                    {a.ts?.length > 0 && <div style={{ marginTop: 8 }}><Detail label="Tech Stack" val={a.ts.join(", ")} /></div>}
                    {a.cb && <div style={{ marginTop: 2 }}><Detail label="Partners" val={a.cb} /></div>}

                    {/* Contacts button */}
                    <button onClick={(e) => { e.stopPropagation(); openContacts(a); }} style={{
                      marginTop: 12, width: "100%", padding: "10px 0", background: `linear-gradient(135deg, ${MC.green}18, ${MC.purple}18)`,
                      border: `1px solid ${MC.green}33`, borderRadius: 8, color: MC.green, fontSize: 13, fontWeight: 600, cursor: "pointer",
                      display: "flex", alignItems: "center", justifyContent: "center", gap: 8,
                    }}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      Contacts & Outreach{ct > 0 ? ` (${ct})` : ""}{cachedCount > 0 ? ` · ${cachedCount} emails ready` : ""}
                    </button>
                  </div>
                )}
              </div>
            );
          })}
        </div>

        {/* RIGHT: Contacts panel */}
        {contactsAcct && (
          <div style={{ background: MC.bgCard, borderRadius: 12, border: `1px solid ${MC.border}`, overflow: "hidden", display: "flex", flexDirection: "column", maxHeight: "76vh" }}>
            {/* Panel header */}
            <div style={{ padding: "14px 18px", borderBottom: `1px solid ${MC.border}`, flexShrink: 0 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <div>
                  <div style={{ fontSize: 16, fontWeight: 700 }}>{contactsAcct.n}</div>
                  <div style={{ fontSize: 11, color: MC.textMuted, marginTop: 2, fontFamily: "'DM Mono', monospace" }}>
                    {contacts.length} contacts · {ec} emails{loading === "contacts" ? " · loading..." : Object.values(loadingEmails).some(Boolean) ? " · generating..." : ""}
                  </div>
                </div>
                <button onClick={() => { genRef.current = null; setContactsAcct(null); setContacts([]); setEmailMap({}); setLoadingEmails({}); setDraftStatus({}); }} style={{ padding: "4px 10px", background: "transparent", color: MC.textMuted, border: `1px solid ${MC.border}`, borderRadius: 6, cursor: "pointer", fontSize: 11 }}>✕</button>
              </div>
              {contacts.length > 0 && (
                <div style={{ display: "flex", gap: 6, marginTop: 10 }}>
                  <button onClick={() => genAllEmails(contacts, contactsAcct)} disabled={Object.values(loadingEmails).some(Boolean)} style={{ flex: 1, padding: "8px 0", background: Object.values(loadingEmails).some(Boolean) ? MC.border : `linear-gradient(135deg, ${MC.green}18, ${MC.purple}18)`, border: `1px solid ${MC.green}33`, borderRadius: 8, color: Object.values(loadingEmails).some(Boolean) ? MC.textMuted : MC.green, fontSize: 12, fontWeight: 600, cursor: Object.values(loadingEmails).some(Boolean) ? "default" : "pointer" }}>
                    {Object.values(loadingEmails).some(Boolean) ? "Generating..." : ec > 0 ? "↻ Regenerate All Emails" : "Generate All Emails"}
                  </button>
                  {ec > 0 && (
                    <button onClick={async () => {
                      const toDraft = contacts.filter(c => emailMap[c.email] && draftStatus[c.email] !== "sent");
                      log(`Drafting ${toDraft.length} emails...`);
                      for (const c of toDraft) { await createDraft(c, emailMap[c.email]); }
                      log("All drafts complete");
                    }} disabled={Object.values(draftStatus).some(s => s === "sending")} style={{ flex: 1, padding: "8px 0", background: MC.amberBg, border: `1px solid ${MC.amberDim}`, borderRadius: 8, color: MC.amber, fontSize: 12, fontWeight: 600, cursor: "pointer" }}>
                      Draft All to Gmail
                    </button>
                  )}
                </div>
              )}
            </div>

            {/* Contacts list with inline emails */}
            <div style={{ flex: 1, overflowY: "auto", padding: "8px 12px" }}>
              {contacts.map((c, i) => (
                <ContactItem key={`${c.email}-${i}`} c={c} email={emailMap[c.email]} isGenning={loadingEmails[c.email]} ds={draftStatus[c.email]} onDraft={createDraft} onRegen={() => genEmail(c, contactsAcct)} />
              ))}
              {contacts.length === 0 && loading === "contacts" && (
                <div style={{ padding: 30, textAlign: "center", fontSize: 12, color: MC.textFaint }}>Loading contacts...</div>
              )}
            </div>

            {/* Panel footer log */}
            <div style={{ padding: "6px 14px", borderTop: `1px solid ${MC.border}`, fontFamily: "'DM Mono', monospace", fontSize: 9, color: MC.textFaint, flexShrink: 0 }}>
              {logs.slice(-2).map((l,i) => <span key={i} style={{ marginRight: 10, opacity: i === 1 ? .6 : .25 }}>{l}</span>)}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
