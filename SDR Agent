// Render email body with clickable links
function EmailBody({ body }) {
  const lines = body?.split("\n").filter(l => l.trim()) || [];
  return <div>{lines.map((line, i) => {
    const isBullet = /^[•\-\*]/.test(line.trim());
    const parts = []; const re = /\[([^\]]+)\]\(([^)]+)\)/g; let m, idx = 0;
    while ((m = re.exec(line)) !== null) {
      if (m.index > idx) parts.push(<span key={`t${i}${idx}`}>{line.slice(idx, m.index)}</span>);
      parts.push(<a key={`l${i}${m.index}`} href={m[2]} target="_blank" rel="noopener" style={{ color: MC.green, textDecoration: "none", borderBottom: `1px solid ${MC.greenDim}` }}>{m[1]}</a>);
      idx = m.index + m[0].length;
    }
    if (idx < line.length) parts.push(<span key={`e${i}`}>{line.slice(idx)}</span>);
    return <div key={i} style={{ marginBottom: isBullet ? 3 : 7, paddingLeft: isBullet ? 4 : 0, color: isBullet ? MC.textDim : MC.text, fontSize: 12, lineHeight: 1.6 }}>{parts.length ? parts : line}</div>;
  })}</div>;
}

