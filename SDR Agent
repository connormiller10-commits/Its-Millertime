async function askClaude(prompt, { mcp = false, web = false } = {}) {
  const body = { model: "claude-sonnet-4-20250514", max_tokens: 4096, system: SYS, messages: [{ role: "user", content: prompt }] };
  if (mcp) body.mcp_servers = MCP_SERVERS;
  if (web) body.tools = [{ type: "web_search_20250305", name: "web_search" }];
  const r = await fetch("https://api.anthropic.com/v1/messages", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) });
  if (!r.ok) throw new Error(`API ${r.status}`);
  const d = await r.json();
  return { texts: d.content?.filter(b => b.type === "text").map(b => b.text) || [], mcpR: d.content?.filter(b => b.type === "mcp_tool_result").map(b => { try { return b.content?.[0]?.text || ""; } catch { return ""; } }) || [] };
}
function parseJ(parts) { for (const t of parts) { try { return JSON.parse(t.replace(/```json|```/g, "").trim()); } catch {} } return null; }
