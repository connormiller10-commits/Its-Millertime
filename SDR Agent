function getPriorities(a) {
  const p = [];
  const stack = (a.ts || []).join(" ").toLowerCase();
  const ind = (a.ind || "").toLowerCase();
  const ik = (a.ik || "").toLowerCase();
  if (stack.includes("databricks") && stack.includes("snowflake")) p.push("Unifying data across Snowflake and Databricks environments");
  else if (stack.includes("databricks")) p.push("Scaling AI/ML workloads on Databricks");
  else if (stack.includes("snowflake")) p.push("Maintaining data reliability across Snowflake pipelines");
  if (stack.includes("dbt")) p.push("Ensuring transformation quality across dbt models");
  if (stack.includes("alation") || stack.includes("atlan")) p.push("Data governance and catalog-driven quality scoring");
  if (ik.includes("data quality")) p.push("Improving data quality at scale without manual rule writing");
  if (ik.includes("informatica")) p.push("Modernizing legacy data quality tooling");
  if (ind.includes("retail") || ind.includes("grocery") || ind.includes("department")) p.push("Trusted data for demand forecasting, inventory, and customer analytics");
  if (ind.includes("financial") || ind.includes("banking") || ind.includes("investment")) p.push("Regulatory-grade data accuracy for financial reporting");
  if (ind.includes("hospital") || ind.includes("health")) p.push("HIPAA-compliant data reliability for clinical and operational analytics");
  if (ind.includes("travel") || ind.includes("airline")) p.push("Real-time data reliability for pricing, operations, and customer experience");
  if (ind.includes("food") || ind.includes("beverage") || ind.includes("restaurant")) p.push("Data-driven supply chain and customer personalization");
  if (ind.includes("motor") || ind.includes("auto")) p.push("Connected vehicle data and manufacturing analytics reliability");
  if (ind.includes("telecom") || ind.includes("wireless")) p.push("Network and customer data reliability at massive scale");
  if (ind.includes("consulting")) p.push("Delivering data observability as a service to enterprise clients");
  if (ind.includes("aerospace") || ind.includes("defense")) p.push("Secure, compliant data infrastructure for mission-critical programs");
  if (ind.includes("electronics") || ind.includes("semiconductor")) p.push("Manufacturing yield optimization through trusted AI/ML data");
